# MySQL Secrets Template
# SECURITY: This file contains PLACEHOLDER values only.
# In production, use SealedSecrets, External Secrets Operator, or SOPS.
# For local development, copy this file to secret.yaml and replace with real base64-encoded values.
#
# Generate base64: echo -n 'your-value' | base64
#
# IMPORTANT: Never commit real secrets to version control.

apiVersion: v1
kind: Secret
metadata:
  name: mysql-secret
  namespace: bank-mall
  labels:
    app: mysql
    app.kubernetes.io/part-of: bank-mall
type: Opaque
data:
  MYSQL_ROOT_PASSWORD: PLACEHOLDER_MYSQL_ROOT_PASSWORD_BASE64
  MYSQL_USER: PLACEHOLDER_MYSQL_USER_BASE64
  MYSQL_PASSWORD: PLACEHOLDER_MYSQL_PASSWORD_BASE64
